def get_mock_scenario(full_user_prompt, agent_system_prompt):
    # full_user_prompt contient TOUT le message envoyé à l'IA.
    # On isole uniquement l'en-tête (les 150 premiers caractères) là où tu 
    # injectes dynamiquement le nom de la cible : "Analysis for: {company_name}"
    # Cela évite les faux positifs avec tes instructions "e.g., Binance, FTX".
    header = full_user_prompt[:150].upper()
    
    # SCÉNARIO A : CRITIQUE (ex: FTX, Binance)
    if "FTX" in header or "BINANCE" in header:
        if "Agent 1" in agent_system_prompt: return '{"total_signals": 15, "highest_severity": 5, "triage_summary": "Fraude massive détectée."}'
        if "Agent 2" in agent_system_prompt: return '{"legal_risk_score": 95, "recommendation": "AVOID", "key_risk_flags": ["Enquête criminelle", "Blanchiment"]}'
        if "Agent 3" in agent_system_prompt: return '{"combined_score": 90, "recommendation": "AVOID", "key_risk_flags": ["CEO arrêté"]}'
        if "Agent 4" in agent_system_prompt: return '{"combined_score": 100, "recommendation": "AVOID", "key_risk_flags": ["Faillite Chapitre 11"]}'
        if "Agent 5" in agent_system_prompt: return '{"overall_evidence_quality": "HIGH", "verified_top_issues": ["Faillite", "Arrestation"]}'
    
    # SCÉNARIO B : SAIN (ex: Apple, Microsoft)
    elif "APPLE" in header or "MICROSOFT" in header:
        if "Agent 1" in agent_system_prompt: return '{"total_signals": 2, "highest_severity": 2, "triage_summary": "Quelques litiges mineurs."}'
        if "Agent 2" in agent_system_prompt: return '{"legal_risk_score": 15, "recommendation": "CLEAR", "key_risk_flags": ["Litige IP mineur"]}'
        if "Agent 3" in agent_system_prompt: return '{"combined_score": 10, "recommendation": "CLEAR", "key_risk_flags": []}'
        if "Agent 4" in agent_system_prompt: return '{"combined_score": 5, "recommendation": "CLEAR", "key_risk_flags": []}'
        if "Agent 5" in agent_system_prompt: return '{"overall_evidence_quality": "HIGH", "verified_top_issues": []}'
    
    # SCÉNARIO C : MITIGÉ (ex: Tesla)
    else:
        if "Agent 1" in agent_system_prompt: return '{"total_signals": 5, "highest_severity": 3, "triage_summary": "Polémiques exécutives et rappels produits."}'
        if "Agent 2" in agent_system_prompt: return '{"legal_risk_score": 40, "recommendation": "MONITOR", "key_risk_flags": ["Amende SEC passée"]}'
        if "Agent 3" in agent_system_prompt: return '{"combined_score": 80, "recommendation": "CAUTION", "key_risk_flags": ["Risque Homme-Clé"]}'
        if "Agent 4" in agent_system_prompt: return '{"combined_score": 30, "recommendation": "MONITOR", "key_risk_flags": ["Rappels sécurité"]}'
        if "Agent 5" in agent_system_prompt: return '{"overall_evidence_quality": "MEDIUM", "verified_top_issues": ["Gouvernance instable"]}'

    if "Agent 6" in agent_system_prompt:
        return '{"decision_intelligence": "VOIR SCORE", "executive_summary": "Rapport généré hors-ligne pour valider l\'architecture."}'


        st.markdown('<div class="agent-card" style="border-left-color: #ff4b4b;"><b>Agent 6 : Orchestrateur</b><br><span class="status-text">Calcul du Cyber Vulnerability Score (CVS) et recommandations</span></div>', unsafe_allow_html=True)
        final = asyncio.run(a6.run_orchestrator_agent(target, "", triage, legal, exec_res, ops, evidence))

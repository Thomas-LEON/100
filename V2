    sys.modules["anthropic"] = mock_anthropic

if "httpx" not in sys.modules:
    mock_httpx = types.ModuleType("httpx")
    class MockClient:
        async def __aenter__(self): return self
        async def __aexit__(self, *args): pass
        async def get(self, *args, **kwargs):
            class Resp:
                def raise_for_status(self): pass
                def json(self): return {"status": "mocked", "results": []}
            return Resp()
    mock_httpx.AsyncClient = MockClient
    mock_httpx.HTTPError = Exception
    sys.modules["httpx"] = mock_httpx

# Chargement chirurgical de tes agents
def load_agent(name):
    path = os.path.join(os.getcwd(), f"{name}.py")
    spec = importlib.util.spec_from_file_location(f"backend.agents.{name}", path)
    mod = importlib.util.module_from_spec(spec)
    mod.__package__ = "backend.agents" # Magie : Répare les imports relatifs
    sys.modules[f"backend.agents.{name}"] = mod
    spec.loader.exec_module(mod)
    return mod

try:
    a1 = load_agent("agent_silobreak")
    a2 = load_agent("agent_legal")
    a3 = load_agent("agent_executive")
    a4 = load_agent("agent_operations")
    a5 = load_agent("agent_evidence")
    a6 = load_agent("agent_orchestrator")
except Exception as e:
    st.error(f"⚠️ Erreur de chargement des fichiers : {e}. Assure-toi de lancer la commande depuis le dossier bnp_agents_test.")
